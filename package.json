{
  "name": "@publr/icons",
  "version": "0.1.0",
  "description": "Framework-neutral UI icons for Publr products",
  "type": "module",
  "sideEffects": false,
  "files": [
    "icons",
    "index.html",
    "src/index.ts",
    "publr_icons.zig",
    "manifest.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./icons/*": "./icons/*",
    "./zig": "./publr_icons.zig",
    "./manifest.json": "./manifest.json"
  },
  "scripts": {
    "build": "node scripts/build.mjs && node scripts/build-gallery.mjs",
    "test": "node --test tests/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
